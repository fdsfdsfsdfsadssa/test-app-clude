<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0A0A1A" android:layoutDirection="rtl">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
        android:orientation="horizontal" android:background="#16163A"
        android:gravity="center_vertical" android:paddingStart="4dp" android:paddingEnd="12dp">
        <ImageButton android:id="@+id/btnBack" android:layout_width="44dp" android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel" android:tint="#AAAACC"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="🎮  إضافة جهاز"
            android:textColor="#FFFFFF" android:textSize="17sp" android:textStyle="bold"
            android:gravity="center"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Device number display (tap to open numpad) -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="رقم الجهاز" android:textColor="#8888AA" android:textSize="13sp"
                android:paddingBottom="4dp"/>
            <TextView android:id="@+id/tvDeviceDisplay"
                android:layout_width="match_parent" android:layout_height="64dp"
                android:background="@drawable/input_tap_bg"
                android:gravity="center" android:textColor="#555577"
                android:textSize="26sp" android:textStyle="bold"
                android:text="اضغط لاختيار رقم الجهاز"/>

            <!-- Session type toggle -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="نوع الجلسة" android:textColor="#8888AA" android:textSize="13sp"
                android:paddingTop="16dp" android:paddingBottom="4dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal">
                <Button android:id="@+id/btnTypeFixed"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:text="⏱  محددة"
                    android:textColor="#FFFFFF" android:textSize="15sp" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnTypeOpen"
                    android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:text="∞  مفتوحة"
                    android:textColor="#FFFFFF" android:textSize="15sp" android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- Fixed session options -->
            <LinearLayout android:id="@+id/layoutFixedOptions"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Hours picker -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="عدد الساعات" android:textColor="#8888AA" android:textSize="13sp"
                    android:paddingTop="16dp" android:paddingBottom="4dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="64dp"
                    android:orientation="horizontal" android:gravity="center"
                    android:background="@drawable/input_bg">
                    <Button android:id="@+id/btnHourMinus"
                        android:layout_width="70dp" android:layout_height="54dp"
                        android:text="−" android:textSize="26sp"
                        android:backgroundTint="#222244" android:textColor="#FFFFFF"/>
                    <TextView android:id="@+id/tvSelectedHours"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center"
                        android:text="1" android:textColor="#FFFFFF"
                        android:textSize="36sp" android:textStyle="bold"/>
                    <Button android:id="@+id/btnHourPlus"
                        android:layout_width="70dp" android:layout_height="54dp"
                        android:text="+" android:textSize="26sp"
                        android:backgroundTint="#003087" android:textColor="#FFFFFF"/>
                </LinearLayout>

                <!-- Calculated price -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingTop="12dp" android:paddingBottom="4dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="السعر:  " android:textColor="#888899" android:textSize="16sp"/>
                    <TextView android:id="@+id/tvCalcPrice"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FFD700" android:textSize="24sp" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Pay now section -->
                <LinearLayout android:id="@+id/layoutPayNow"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#222244" android:layout_marginTop="8dp" android:layout_marginBottom="12dp"/>
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="المبلغ المدفوع من الزبون" android:textColor="#8888AA"
                        android:textSize="13sp" android:paddingBottom="4dp"/>
                    <TextView android:id="@+id/tvPaidDisplay"
                        android:layout_width="match_parent" android:layout_height="64dp"
                        android:background="@drawable/input_tap_bg"
                        android:gravity="center|end" android:paddingEnd="16dp"
                        android:textColor="#555577" android:textSize="26sp" android:textStyle="bold"
                        android:text="اضغط لإدخال المبلغ"/>
                    <TextView android:id="@+id/tvChange"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center" android:textSize="18sp" android:textStyle="bold"
                        android:paddingTop="8dp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Confirm button -->
    <Button android:id="@+id/btnConfirm"
        android:layout_width="match_parent" android:layout_height="58dp"
        android:text="✅  تأكيد وتسجيل الجهاز"
        android:backgroundTint="#222233" android:textColor="#FFFFFF"
        android:textSize="16sp" android:textStyle="bold"
        android:layout_margin="10dp"/>
</LinearLayout>
