<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A1A"
    android:layoutDirection="rtl">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#16163A"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#AAAACC"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎮  إضافة جهاز"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Device number -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="رقم الجهاز / البلايستيشن"
                android:textColor="#AAAACC"
                android:textSize="14sp"
                android:paddingBottom="4dp"/>

            <EditText
                android:id="@+id/etDeviceNumber"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:inputType="text"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:background="@drawable/input_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:hint="مثال: 1 أو PS5-A"
                android:textColorHint="#555577"/>

            <!-- Hours picker -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="عدد الساعات"
                android:textColor="#AAAACC"
                android:textSize="14sp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/input_bg">

                <Button
                    android:id="@+id/btnHourMinus"
                    android:layout_width="60dp"
                    android:layout_height="50dp"
                    android:text="−"
                    android:textSize="24sp"
                    android:backgroundTint="#222244"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:id="@+id/tvSelectedHours"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btnHourPlus"
                    android:layout_width="60dp"
                    android:layout_height="50dp"
                    android:text="+"
                    android:textSize="24sp"
                    android:backgroundTint="#003087"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- Price display -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="20dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="السعر الإجمالي: "
                    android:textColor="#AAAACC"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvCalculatedPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFD700"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#222244"
                android:layout_marginBottom="20dp"/>

            <!-- Amount paid -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المبلغ المدفوع من الزبون"
                android:textColor="#AAAACC"
                android:textSize="14sp"
                android:paddingBottom="4dp"/>

            <EditText
                android:id="@+id/etAmountPaid"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:background="@drawable/input_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:hint="0"
                android:textColorHint="#555577"/>

            <!-- Change display -->
            <TextView
                android:id="@+id/tvChange"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Confirm button -->
    <Button
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="✅  تأكيد وتسجيل الجهاز"
        android:backgroundTint="#006600"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        android:layout_margin="12dp"/>

</LinearLayout>
