<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0A0A1A" android:layoutDirection="rtl">

    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
        android:orientation="horizontal" android:background="#16163A"
        android:gravity="center_vertical" android:paddingStart="4dp" android:paddingEnd="12dp">
        <ImageButton android:id="@+id/btnBack" android:layout_width="44dp" android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel" android:tint="#AAAACC"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="📅  سجل الأيام السابقة"
            android:textColor="#FFFFFF" android:textSize="17sp" android:textStyle="bold"
            android:gravity="center"/>
    </LinearLayout>

    <ListView android:id="@+id/lvDays"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:divider="#1A1A40" android:dividerHeight="1dp"/>
    <TextView android:id="@+id/tvNoDays"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:gravity="center"
        android:text="لا توجد أيام سابقة" android:textColor="#333355"
        android:textSize="16sp" android:visibility="gone"/>
</LinearLayout>
