<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A1A"
    android:layoutDirection="rtl">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#16163A"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#AAAACC"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚙️  الإعدادات"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="سعر الساعة"
                android:textColor="#AAAACC"
                android:textSize="14sp"
                android:paddingBottom="4dp"/>

            <EditText
                android:id="@+id/etPricePerHour"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:background="@drawable/input_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:hint="مثال: 10"
                android:textColorHint="#555577"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="العملة"
                android:textColor="#AAAACC"
                android:textSize="14sp"
                android:paddingTop="20dp"
                android:paddingBottom="4dp"/>

            <EditText
                android:id="@+id/etCurrency"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:inputType="text"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:background="@drawable/input_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:hint="مثال: ج.م"
                android:textColorHint="#555577"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="32dp"
                android:text="💾  حفظ الإعدادات"
                android:backgroundTint="#003087"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
