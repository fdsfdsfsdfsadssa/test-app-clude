<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0A0A1A" android:layoutDirection="rtl">

    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
        android:orientation="horizontal" android:background="#16163A"
        android:gravity="center_vertical" android:paddingStart="4dp" android:paddingEnd="12dp">
        <ImageButton android:id="@+id/btnBack" android:layout_width="44dp" android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel" android:tint="#AAAACC"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="⚙️  الإعدادات"
            android:textColor="#FFFFFF" android:textSize="17sp" android:textStyle="bold"
            android:gravity="center"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent"
        android:padding="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="سعر الساعة (اضغط للتعديل)" android:textColor="#8888AA"
                android:textSize="13sp" android:paddingBottom="4dp"/>
            <TextView android:id="@+id/tvPriceDisplay"
                android:layout_width="match_parent" android:layout_height="64dp"
                android:background="@drawable/input_tap_bg"
                android:gravity="center" android:textColor="#FFD700"
                android:textSize="24sp" android:textStyle="bold" android:text="10 ج.م / ساعة"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="العملة" android:textColor="#8888AA" android:textSize="13sp"
                android:paddingTop="20dp" android:paddingBottom="8dp"/>
            <LinearLayout android:id="@+id/currencyContainer"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="وضع الاختبار" android:textColor="#8888AA" android:textSize="13sp"
                android:paddingTop="24dp" android:paddingBottom="8dp"/>
            <Button android:id="@+id/btnTestMode"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="وضع الاختبار: مغلق"
                android:backgroundTint="#222244" android:textColor="#FFFFFF" android:textSize="14sp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="في وضع الاختبار: 10 ثوان = 1 ساعة، و5 ثوان = نص ساعة للحساب"
                android:textColor="#555577" android:textSize="11sp" android:paddingTop="4dp"/>

            <Button android:id="@+id/btnSave"
                android:layout_width="match_parent" android:layout_height="54dp"
                android:layout_marginTop="32dp" android:text="💾  حفظ الإعدادات"
                android:backgroundTint="#003087" android:textColor="#FFFFFF"
                android:textSize="16sp" android:textStyle="bold"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
